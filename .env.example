# ============================================================
# ListFlow — Environment Variables
# Copy this file to .env.local and fill in your values.
# ============================================================

NODE_ENV=development

# ── Core ─────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-random-32-char-string-here
NEXTAUTH_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Branding ─────────────────────────────────────────────────
BRAND_NAME=My Store
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── AI Content Generation (optional) ────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash
AI_DAILY_BUDGET_CENTS=500

# ── eBay (optional) ─────────────────────────────────────────
# Get tokens at https://developer.ebay.com
EBAY_OAUTH_TOKEN=
EBAY_ENVIRONMENT=sandbox
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_WEBHOOK_VERIFICATION_TOKEN=

# ── Etsy (optional) ─────────────────────────────────────────
# Get tokens at https://www.etsy.com/developers
ETSY_API_KEY=
ETSY_OAUTH_TOKEN=
ETSY_SHOP_ID=
ETSY_WEBHOOK_SECRET=

# ── Amazon (optional) ───────────────────────────────────────
AMAZON_SELLER_ID=

# ── Telegram Bot (optional) ─────────────────────────────────
# Create a bot via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret-min-16-chars
TELEGRAM_ADMIN_CHAT_IDS=123456789

# ── Cron / QStash (optional) ────────────────────────────────
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
